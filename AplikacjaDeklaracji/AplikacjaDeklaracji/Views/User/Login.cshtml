@model AplikacjaDeklaracji.Models.User
@{
    ViewData["Title"] = "Login";
}

<head>
    <link rel="stylesheet" href="~/css/Loginstyles.css" />
</head>

<br />
<form method="post" asp-action="LoginUser">
    <div class="username">
        <label>Nazwa użytkownika:</label>
        <input type="text" name="Username" required />
        <span asp-validation-for="Username"></span><br />

    </div>
    <div class="password">
        <label>Hasło:</label>
        <input name="PasswordHash" type="password" required /><br />
    </div>
    <div class="loginbtn">
        <button type="submit">Login</button><br />
    </div>
</form>
<br />
@if (TempData["Alert"] != null)
{
    <div class="alert alert-danger ">
        @TempData["Alert"]
    </div>
}
<br />
<a asp-controller="User" asp-action="register" class="registerlink">Utwórz nowe konto</a>
<br />